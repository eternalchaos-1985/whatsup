# Backend Environment Variables
# Replace placeholder values with your actual API keys

# Server
PORT=3000
NODE_ENV=development

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="your-private-key"

# API Keys
PAGASA_API_URL=https://bagong.pagasa.dost.gov.ph/api
PHIVOLCS_API_URL=https://earthquake.phivolcs.dost.gov.ph
IQAIR_API_KEY=your-iqair-api-key
OPENAQ_API_URL=https://api.openaq.org/v2
NEWS_API_KEY=your-newsapi-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_CIVIC_API_KEY=your-google-civic-api-key
NASA_FIRMS_MAP_KEY=your-nasa-firms-map-key
EVENTBRITE_API_KEY=your-eventbrite-api-key
